# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/cardapify?schema=public"

# JWT Secret
JWT_SECRET="change-this-secret-in-production"
JWT_REFRESH_SECRET="change-this-refresh-secret-in-production"

# Server Port
PORT=3001

# CORS Origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Payment Gateway (mock | mercadopago)
PAYMENT_GATEWAY=mock

# Mercado Pago (production)
# MERCADOPAGO_ACCESS_TOKEN=your_token_here
